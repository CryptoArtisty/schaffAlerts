# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# These will be auto-filled by Vercel when you add databases
# You don't need to set these manually
POSTGRES_URL=vercel_will_auto_fill_this
KV_URL=vercel_will_auto_fill_this
KV_REST_API_URL=vercel_will_auto_fill_this
KV_REST_API_TOKEN=vercel_will_auto_fill_this
